NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_V3JmyojHfTThe3odVgbbZQ_wCrhO3kD

# --- AI model (optional) ----------------------------------------------------
# Gemini via Google Vertex AI. Vertex uses IAM, NOT an API key.
# LOCAL: run once  ->  gcloud auth application-default login
#        then set the project below. The Google SDK finds the creds (ADC).
# Without these, the app runs the deterministic grounded fallback (no model).
GOOGLE_VERTEX_PROJECT=ferrous-wonder-491213-e7
# GOOGLE_VERTEX_LOCATION=us-central1   # e.g. europe-west1 for EU residency
# GOOGLE_VERTEX_MODEL=gemini-2.5-flash
