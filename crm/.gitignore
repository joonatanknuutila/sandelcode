# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# playwright (eval suite)
/test-results/
/playwright-report/

# QA tooling + captured screenshots/logs (not product source)
/.qa/

# generated seed output (generate.mjs is the source of truth)
/seed/out/

# typescript
*.tsbuildinfo
next-env.d.ts
